{
  "name": "concensus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start-dev": "vite",
    "build": "vue-tsc -b && vite build",
    "check": "vue-tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "vite preview",
    "deploy:aws": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-aws.ps1"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  }
